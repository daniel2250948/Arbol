class Nodo:
  def __init__(self, val):
    self.val = val
    self.left = None
    self.right= None

class Arbol:
  def __init__(self, val):
    self.root = Nodo(val)

  def __agregar_recursivo(self, nodo, val):
        if val < nodo.val:
            if nodo.left is None:
                nodo.left = Nodo(val)
            else:
                self.__agregar_recursivo(nodo.left, val)
        else:
            if nodo.right is None:
                nodo.right = Nodo(val)
            else:
                self.__agregar_recursivo(nodo.right, val)


